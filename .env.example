# Environment Variables
# Copy this file to .env and fill in the values

# Port for the Node.js server to run on locally (default is 3000)
PORT=3000

# Connection URL for PostgreSQL (used on Render/production)
# Leave blank to use local SQLite instead
DATABASE_URL=

# Groq API Key for the Llama 3 AI Summarization
# Get a free key at: https://console.groq.com/keys
GROQ_API_KEY=
